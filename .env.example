# Public canonical URL used for metadata, OpenGraph, and sitemap.
# Defaults to https://galleryuk.vercel.app when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps JavaScript API key — used only on the /map page.
# The map page falls back to a list-only view when this is unset, so
# it is safe to develop locally without one. Restrict the production
# key to your canonical domains via the Google Cloud console.
# https://developers.google.com/maps/documentation/javascript/get-api-key
NEXT_PUBLIC_GMAPS_KEY=
